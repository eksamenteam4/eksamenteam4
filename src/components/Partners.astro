<style>
  .partners {
    padding: 3rem 1rem;
    background: #f5f5f5;
  }

  .partners__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* MOBILE FIRST */
  .partners__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .partners__item {
    background: white;
    border-radius: 14px;
    padding: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #e5e5e5;
    transition: transform 0.2s ease;
    min-height: 90px;
  }

  .partners__item:hover {
    transform: translateY(-3px);
  }

  .partners__item img {
    width: 100%;
    max-width: 100px;
    max-height: 35px;
    object-fit: contain;
  }

  .partners__footer {
    text-align: center;
    margin-top: 1.8rem;
    color: #777;
    font-size: 0.9rem;
  }

  /* TABLET */
  @media (min-width: 700px) {
    .partners {
      padding: 4rem 2rem;
    }

    .partners__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .partners__item {
      padding: 1.5rem;
      min-height: 110px;
    }

    .partners__item img {
      max-width: 120px;
      max-height: 40px;
    }
  }

  /* DESKTOP */
  @media (min-width: 1024px) {
    .partners__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    .partners__item {
      padding: 2rem;
    }
  }
</style>