<style>
  .partners {
    padding: 4rem 2rem;
    background: #f5f5f5;
  }

  .partners__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .partners__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .partners__item {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #e5e5e5;
    transition: 0.2s ease;
  }

  .partners__item:hover {
    transform: translateY(-3px);
  }

  .partners__item img {
    max-width: 120px;
    max-height: 40px;
    object-fit: contain;
  }

  .partners__footer {
    text-align: center;
    margin-top: 2rem;
    color: #777;
    font-size: 0.9rem;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .partners__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .partners__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>