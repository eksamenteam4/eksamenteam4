<section class="pictures">
  <div class="pictures__container">

    <div class="pictures__header">
      <h2>Oplev området</h2>
    </div>

    <div class="pictures__scroll">
    
        <div class="pictures__item">
          <img src="" alt="Billede af området" />
        </div>
      ))
    </div>

  </div>
</section>

<style>
  .pictures {
    padding: 4rem 1.5rem;
    background: #f7f5f2;
  }

  .pictures__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .pictures__header {
    margin-bottom: 1.5rem;
  }

  .pictures__header h2 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 600;
    color: #1f1f1f;
  }

  .pictures__scroll {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 0.5rem;
  }

  .pictures__scroll::-webkit-scrollbar {
    height: 6px;
  }

  .pictures__scroll::-webkit-scrollbar-thumb {
    background: #c8c8c8;
    border-radius: 999px;
  }

  .pictures__item {
    min-width: 320px;
    height: 420px;
    border-radius: 24px;
    overflow: hidden;
    flex-shrink: 0;
    scroll-snap-align: start;
    position: relative;
  }

  .pictures__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pictures__item:hover img {
    transform: scale(1.03);
  }

  @media (max-width: 768px) {
    .pictures {
      padding: 3rem 1rem;
    }

    .pictures__item {
      min-width: 240px;
      height: 320px;
      border-radius: 18px;
    }
  }
</style>