---
const {
  image,
  heading,
  title,
  description,
  buttonText,
  variant
} = Astro.props;
---

<section class={`hero_picture ${variant}`}>
  <img src={image} alt="" />

  <div class="dankort">
    <h1 set:html={heading} />
  </div>

  <div class="sejt">
    <h1>{title}</h1>
    <p>{description}</p>

    {buttonText && (
      <button class="bestil">
        {buttonText} <span>→</span>
      </button>
    )}
  </div>
</section>

<style>
  .hero_picture img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bestil {
    background-color: #e21e27;
    border-radius: 25px;
    border: none;
    padding: 6px 20px;
    color: white;
  }

  .red {
    color: red;
  }

  .sejt {
    position: absolute;
    bottom: 100px;
    left: 80px;
    color: white;
  }

  .dankort {
    position: relative;
    top: 40px;
  }

  /* VARIATION 1 */
  .hero--landscape .dankort {
    right: 120px;
  }

  /*VARIATION 2 */
  .hero--strand .dankort {
    right: 45px;
  }
</style>