---
const {
  image,
  heading,
  title,
  description,
  buttonText,
  variant
} = Astro.props;
---

<section class={`hero_picture ${variant}`}>
  <img src={image} alt="" />

  <div class="dankort">
    <h1 set:html={heading} />
  </div>

  <div class="sejt">
    <h1>{title}</h1>
    <p>{description}</p>

    {buttonText && (
      <a  href="/form/">
      <button class="bestil">
        {buttonText} <span>→</span>
      </button>
      </a>
    )}
  </div>
</section>

<style>
  .hero_picture img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bestil {
    background-color: #e21e27;
    border-radius: 25px;
    border: none;
    padding: 6px 20px;
    color: white;
  }

  .red {
    color: red;
  }

  .sejt {
    position: absolute;
    bottom: 60px;
    left: 40px;
    color: white;
  }

  .dankort {
    position: absolute;
    top: 15px;
    padding-right: 10px;
  }

  h1 {
font-size: 3vw;
  }

  .hero_picture{
    position: relative;
  }

  /* VARIATION 1 */
  .hero--landscape .dankort {
    right: 20px;
  }

  /*VARIATION 2 */
  .hero--strand .dankort {
    right: 20px;
  }
    @media screen and (min-width: 701px) {
    .dankort {
    top: 40px;
  }
    .sejt {
    bottom: 100px;
    left: 80px;
    }
  }
</style>