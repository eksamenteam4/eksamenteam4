<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
  .burger {
    display: block;
  }

  .menu {
    display: none;
  }
      .menu.open {
  display: flex;
  flex-direction: column;
  gap: 15px;
  position: absolute;
  top: 90px;
  left: 0;
  right: 0;
  background: #e9e9e9;
  padding: 20px 64px;
}


  .header {
    display: flex;
    background: #e9e9e9;
  justify-content: space-between; 
    height: 90px;
    align-items: center;
    padding: 0 64px;
  }
  


  @media screen and (min-width: 900px) {
    .burger {
      display: none;
    }
    .menu {
      position: static;
    display: flex;
    flex-direction: row;
    gap: 30px;
    padding: 0;
    }

  }

</style>
<script>
  window.addEventListener("DOMContentLoaded", () => {
    const burger = document.querySelector(".burger");
    const menu = document.querySelector(".menu");

    burger.addEventListener("click", () => {
      menu.classList.toggle("open");
    });
  });
</script>