---
import Header from '../../components/Header.astro';

import Map from '../../components/Map.astro';
import Partners from '../../components/Partners.astro';
import Cta from '../../components/Cta.astro';
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';
export async function getStaticPaths() {
    const endpoint = "https://appumwlllsxyfwtyvmsg.supabase.co/rest/v1/projects?select=*";
const key = "sb_publishable_Bm9oMslCGTUIlechk_bY4Q_YYycMyRe";
const options={
	headers:{
		apikey: key,
	},};
  const response = await fetch(endpoint, options);
  const data = await response.json();

  return data.map((product) => {
    return {
      params: { id: product.id.toString() },
      props: { product }, 
    };
  });
}

const { id } = Astro.params;
const { product  } = Astro.props;
---
<Layout>
    <Header />
<article >
   
  <div class="top">
     
    <div class="toptext">
        <a href="/#projekter"> Tilbage til projekter</a> 
    <h3 class="location-badge">{product.location}</h3>
    <h2>{product.title}</h2>
    <h4 class="description">
      {product.short_description}
    </p>
    </div>
    <img src={product.image} alt="productimage" />
</div>

    <section class="cardtext">
    
<div class="inline">
    <p class="area">{product.area}</p>
    <p class="area">{product.location}</p>
    <p class="area">{product.status}</p>
    </div>
  
  <div class="hvorfortext">
    <h3>Hvorfor støtter vi dette område?</h3>
    <p class="longtext">{product.about}</p>
  </div>

  <div class="greenbackground">
    <div>
    <h3>Hvad betyder din betaling?</h3>
    <p class="longtext">{product.payment}</p>
    </div>
    <img src="/img/productdetails.webp" alt="trees"/>
  </div>
  </section>
  <Map />
</article>
 <Partners />
 <Cta />
<Footer />
</Layout>
<style>

 h2, h4, a {
    color: white;
    text-decoration: none;
 }

/* IMAGE SECTION */
.top {
  position: relative;
  height: 500px;
  overflow: hidden;
}

.top img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.location-badge {
  background: rgba(255, 255, 255, 0.5);
  color: #4f6f52;
  border-radius: 30px;
  font-size: 14px;
  font-weight: 600;
  backdrop-filter: blur(6px);
  z-index: 2;
  margin-top: 20%;
  padding: 10px;
  width: fit-content;
}
.toptext {
    position: absolute;
    padding-left: 50px;
    padding-top: 30px;
}

.hvorfortext {
    padding: 30px;
}

.cardtext {
  max-width: 100%;
  background: #f5f5f3;
  border-radius: 30px;
  overflow: hidden; 
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  margin-top: 50px;
padding-top: 40px;
}

.inline {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr ;
    border-bottom: 2px solid rgb(168, 167, 167);
padding-bottom: 30px;
}

/* AREA TAG */
.area {
  width: fit-content;
  padding: 10px 16px;
  background: #dcebd8;
  border-radius: 16px;
  color: #4f6f52;
  justify-self: center;
}

.longtext {
    max-width: 60%;
}

.greenbackground {
    background-color: #D0EBD4;
    border-radius: 30px;
    padding: 30px;
   margin-top: 50px;
   display: grid;
   grid-template-columns: 1fr 1fr;
}

	 @media (max-width: 900px) {
.inline {
display: block;
}
.greenbackground {
    display: block;
}
     }
</style>